// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SysRole {
  owner
  manager
  team_lead
  employee
}

enum channelType {
  text
  announcement
}

enum EmbedStatus {
  pending
  processing
  done
  failed
}

enum InviteStatus {
  pending
  accepted
  expired
  rejected
}

enum notificationType {
  task_assigned

  subtask_assigned
  subtask_completed

  workitem_assigned
  workitem_in_review
  workitem_approved
  workitem_rejected

  project_completed
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
  cancelled
}

enum TaskStatus {
  todo
  in_progress
  in_review
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  password     String
  avatar       String?
  isActive     Boolean @default(true)
  refreshToken String?

  ownedWorkspaces            Workspace[]         @relation("WorkspaceOwner")
  workspaceMembers           WorkspaceMember[]
  managedDepartments         Department[]        @relation("DepartmentManager")
  teamLeaders                Team[]              @relation("TeamLeader")
  teamMembers                TeamMember[]        @relation("UserTeamMembership")
  messages                   Message[]           @relation("MessageSender")
  deletedMessages            Message[]           @relation("MessageDeletedBy")
  MessageReactions           MessageReaction[]
  uploadedFile               File[]              @relation("FileUploader")
  notifications              Notification[]
  auditLogs                  AuditLog[]          @relation("AuditActor")
  workspaceInviteByYou       WorkspaceInvite[]   @relation("InvitedBy")
  projects                   Project[]           @relation("ProjectCreator")
  projectTeamsAssigned       ProjectTeam[]       @relation("ProjectTeamAssigner")
  projectDepartmentsAssigned ProjectDepartment[] @relation("ProjectDepartmentAssigner")
  tasksCreated               Task[]              @relation("TaskCreator")
  subtasksCreated            SubTask[]           @relation("SubTaskCreator")
  assignedSubTasks SubTask[] @relation("AssignedSubTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Workspace {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  logo String?

  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  ownerId String

  workspaceMembers WorkspaceMember[]
  departments      Department[]
  files            File[]
  auditLogs        AuditLog[]
  workspaceInvites WorkspaceInvite[] @relation("WorkspaceInvites")
  projects         Project[]         @relation("projectsOfWorkspace")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id        String   @id @default(cuid())
  sys_role  SysRole  @default(employee)
  work_role String?
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model WorkspaceInvite {
  id            String       @id @default(cuid())
  workspace     Workspace    @relation("WorkspaceInvites", fields: [workspaceId], references: [id])
  workspaceId   String
  email         String
  sys_role      SysRole
  work_role     String?
  token         String       @unique
  invitedByUser User         @relation("InvitedBy", fields: [invitedBy], references: [id])
  invitedBy     String
  status        InviteStatus @default(pending)
  expiresAt     DateTime
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([workspaceId, email])
  @@index([email])
}

model Department {
  id         String    @id @default(cuid())
  name       String
  is_deleted Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  manager   User?   @relation("DepartmentManager", fields: [managerId], references: [id])
  managerId String?

  teams    Team[]
  projects ProjectDepartment[] @relation("departmentsOfProject")

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([managerId])
}

model Team {
  id           String     @id @default(cuid())
  name         String
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
  leader       User?      @relation("TeamLeader", fields: [leaderId], references: [id])
  leaderId     String?
  is_deleted   Boolean    @default(false)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  teamMembers  TeamMember[]
  channels     Channel[]
  teamProjects ProjectTeam[] @relation("teams")

  @@unique([departmentId, name])
  @@index([departmentId])
  @@index([leaderId])
}

model TeamMember {
  id       String   @id @default(cuid())
  team     Team     @relation(fields: [teamId], references: [id])
  teamId   String
  member   User     @relation("UserTeamMembership", fields: [memberId], references: [id])
  memberId String
  joinedAt DateTime @default(now())

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
}

// POST   /team/:teamId/member
// GET    /team/:teamId/members
// DELETE /team/:teamId/member/:memberId

model Channel {
  id         String      @id @default(cuid())
  name       String
  type       channelType @default(text)
  team       Team        @relation(fields: [teamId], references: [id])
  teamId     String
  is_deleted Boolean     @default(false)
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  messages Message[]

  @@unique([teamId, name])
  @@index([teamId])
}

model Message {
  id         String    @id @default(cuid())
  content    String
  is_edited  Boolean   @default(false)
  editedAt   DateTime?
  is_deleted Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  channel       Channel  @relation(fields: [channelId], references: [id])
  channelId     String
  sender        User     @relation("MessageSender", fields: [senderId], references: [id])
  senderId      String
  parent        Message? @relation("MessageReplies", fields: [parentId], references: [id])
  parentId      String?
  deletedByUser User?    @relation("MessageDeletedBy", fields: [deletedBy], references: [id])
  deletedBy     String?

  replies          Message[]         @relation("MessageReplies")
  messageReactions MessageReaction[]

  @@index([channelId, createdAt])
  @@index([senderId])
  @@index([parentId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  message   Message  @relation(fields: [messageId], references: [id])
  messageId String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model File {
  id               String      @id @default(cuid())
  name             String
  url              String
  mime_string      String
  size             Int
  is_folder        Boolean     @default(false)
  embedding_status EmbedStatus @default(pending)
  is_deleted       Boolean     @default(false)
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId    String
  uploadedByUser User      @relation("FileUploader", fields: [uploadedBy], references: [id])
  uploadedBy     String
  parent         File?     @relation("RelationToParentFolder", fields: [parentId], references: [id])
  parentId       String?

  subFiles File[] @relation("RelationToParentFolder")

  @@index([workspaceId])
  @@index([uploadedBy])
  @@index([parentId])
  @@index([embedding_status])
}

model Notification {
  id        String           @id @default(cuid())
  type      notificationType
  payload   Json
  is_read   Boolean          @default(false)
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@index([userId, is_read])
  @@index([userId, createdAt])
}

model AuditLog {
  id           String    @id @default(cuid())
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId  String
  actor        User      @relation("AuditActor", fields: [actorId], references: [id])
  actorId      String
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([actorId])
  @@index([resourceType, resourceId])
}

model Project {
  id String @id @default(cuid())

  name        String
  description String?

  workspaceId String
  workspace   Workspace @relation("projectsOfWorkspace", fields: [workspaceId], references: [id])

  createdById String
  createdBy   User   @relation("ProjectCreator", fields: [createdById], references: [id])

  status ProjectStatus @default(planning)

  startDate DateTime?
  dueDate   DateTime?

  is_deleted Boolean   @default(false)
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectDepartments ProjectDepartment[] @relation("projectDepartments")

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([createdById])
  @@index([status])
}


model ProjectDepartment {
  id String @id @default(cuid())

  projectId String
  project   Project @relation("projectDepartments", fields: [projectId], references: [id])

  departmentId String
  department   Department @relation("departmentsOfProject", fields: [departmentId], references: [id])

  assignedById String
  assignedBy   User   @relation("ProjectDepartmentAssigner", fields: [assignedById], references: [id])

  assignedAt DateTime @default(now())

  projectTeams ProjectTeam[] @relation("projectDepartment")

  @@unique([projectId, departmentId])
  @@index([projectId])
  @@index([departmentId])
}
 model ProjectTeam {
  id String @id @default(cuid())

  projectDepartmentId String
  projectDepartment   ProjectDepartment @relation("projectDepartment", fields: [projectDepartmentId], references: [id])

  teamId String
  team   Team   @relation("teams", fields: [teamId], references: [id])

  assignedById String
  assignedBy   User   @relation("ProjectTeamAssigner", fields: [assignedById], references: [id])

  assignedAt DateTime @default(now())

  tasks Task[] @relation("taskAndProjectTeam")

  @@unique([projectDepartmentId, teamId])
  @@index([projectDepartmentId])
  @@index([teamId])
}


model Task {
  id String @id @default(cuid())

  title String
  description String?

  projectTeamId String
  projectTeam ProjectTeam @relation("taskAndProjectTeam",fields:[projectTeamId],references:[id])

  createdById String
  createdBy User @relation("TaskCreator",fields:[createdById],references:[id])

  status TaskStatus @default(todo)

  priority TaskPriority @default(medium)

  progress Int @default(0)

  dueDate DateTime?

  is_deleted Boolean @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subtasks SubTask[]    @relation("SubTaskOfTask")

  @@index([projectTeamId])
  @@index([createdById])
  @@index([status])
}


model SubTask {
  id String @id @default(cuid())

  title String
  description String?

  taskId String
  task Task @relation("SubTaskOfTask",fields:[taskId],references:[id])

  assignedToId String?
  assignedTo User? @relation("AssignedSubTasks",fields:[assignedToId],references:[id])

  assignedById String
  assignedBy User @relation("SubTaskCreator",fields:[assignedById],references:[id])

  status TaskStatus @default(todo)

  priority TaskPriority @default(medium)

  progress Int @default(0)

  dueDate DateTime?

  is_deleted Boolean @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workItems WorkItem[]

  @@index([taskId])
  @@index([assignedToId])
  @@index([assignedById])
  @@index([status])
}

model WorkItem {
  id String @id @default(cuid())

  title String
  description String?

  subTaskId String
  subTask SubTask @relation(fields:[subTaskId],references:[id])

  status TaskStatus @default(todo)

  priority TaskPriority @default(medium)

  estimatedHours Int?

  actualHours Int?

  completedAt DateTime?

  is_deleted Boolean @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subTaskId])
  @@index([status])
}
