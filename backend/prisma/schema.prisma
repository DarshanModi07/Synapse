// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SysRole {
  owner
  manager
  team_lead
  employee
}

enum channelType {
  text
  announcement
}

enum EmbedStatus {
  pending
  processing
  done
  failed
}

enum notificationType {
  mention
  file_shared
  role_change
  invited_to_workspace
  invited_to_team
  ai_done
  message_reaction
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  avatar   String?
  isActive Boolean @default(true)
  refreshToken String?

  ownedWorkspaces    Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers   WorkspaceMember[]
  managedDepartments Department[]      @relation("DepartmentManager")
  teamLeaders        Team[]            @relation("TeamLeader")
  teamMembers        TeamMember[]      @relation("UserTeamMembership")
  messages           Message[]         @relation("MessageSender")
  deletedMessages    Message[]         @relation("MessageDeletedBy")
  MessageReactions   MessageReaction[]
  uploadedFile       File[]            @relation("FileUploader")
  notifications      Notification[]
  auditLogs          AuditLog[]        @relation("AuditActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Workspace {
  id   String  @id @default(cuid())
  name String
  slug String  @unique
  logo String?

  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  ownerId String

  workspaceMembers WorkspaceMember[]
  departments      Department[]
  files            File[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  auditLogs AuditLog[]

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id        String   @id @default(cuid())
  sys_role  SysRole  @default(employee)
  work_role String?
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Department {
  id         String    @id @default(cuid())
  name       String
  is_deleted Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  manager   User   @relation("DepartmentManager", fields: [managerId], references: [id])
  managerId String

  teams Team[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([managerId])
}

model Team {
  id           String     @id @default(cuid())
  name         String
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
  leader       User       @relation("TeamLeader", fields: [leaderId], references: [id])
  leaderId     String
  is_deleted   Boolean    @default(false)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  teamMembers TeamMember[]
  channels    Channel[]

  @@unique([departmentId, name])
  @@index([departmentId])
  @@index([leaderId])
}

model TeamMember {
  id       String   @id @default(cuid())
  team     Team     @relation(fields: [teamId], references: [id])
  teamId   String
  member   User     @relation("UserTeamMembership", fields: [memberId], references: [id])
  memberId String
  joinedAt DateTime @default(now())

  @@unique([teamId, memberId])
  @@index([teamId])
  @@index([memberId])
}

model Channel {
  id         String      @id @default(cuid())
  name       String
  type       channelType @default(text)
  team       Team        @relation(fields: [teamId], references: [id])
  teamId     String
  is_deleted Boolean     @default(false)
  deletedAt  DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  messages Message[]

  @@unique([teamId, name])
  @@index([teamId])
}

model Message {
  id         String    @id @default(cuid())
  content    String
  is_edited  Boolean   @default(false)
  editedAt   DateTime?
  is_deleted Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  channel       Channel  @relation(fields: [channelId], references: [id])
  channelId     String
  sender        User     @relation("MessageSender", fields: [senderId], references: [id])
  senderId      String
  parent        Message? @relation("MessageReplies", fields: [parentId], references: [id])
  parentId      String?
  deletedByUser User?    @relation("MessageDeletedBy", fields: [deletedBy], references: [id])
  deletedBy     String?

  replies          Message[]         @relation("MessageReplies")
  messageReactions MessageReaction[]

  @@index([channelId, createdAt])
  @@index([senderId])
  @@index([parentId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  message   Message  @relation(fields: [messageId], references: [id])
  messageId String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model File {
  id               String      @id @default(cuid())
  name             String
  url              String
  mime_string      String
  size             Int
  is_folder        Boolean     @default(false)
  embedding_status EmbedStatus @default(pending)
  is_deleted       Boolean     @default(false)
  deletedAt        DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId    String
  uploadedByUser User      @relation("FileUploader", fields: [uploadedBy], references: [id])
  uploadedBy     String
  parent         File?     @relation("RelationToParentFolder", fields: [parentId], references: [id])
  parentId       String?

  subFiles File[] @relation("RelationToParentFolder")

  @@index([workspaceId])
  @@index([uploadedBy])
  @@index([parentId])
  @@index([embedding_status])
}

model Notification {
  id        String           @id @default(cuid())
  type      notificationType
  payload   Json
  is_read   Boolean          @default(false)
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@index([userId, is_read])
  @@index([userId, createdAt])
}

model AuditLog {
  id           String    @id @default(cuid())
  workspace    Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId  String
  actor        User      @relation("AuditActor", fields: [actorId], references: [id])
  actorId      String
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  @@index([workspaceId, createdAt])
  @@index([actorId])
  @@index([resourceType, resourceId])
}
